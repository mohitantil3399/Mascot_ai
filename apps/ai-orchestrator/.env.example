# Antigravity Companion - Environment Configuration
# Copy this file to `.env` and fill in your own API keys.
#
# Get a free Mistral API key at: https://console.mistral.ai
# Get an OpenRouter key at: https://openrouter.ai/keys
# Get an OpenAI key at: https://platform.openai.com/api-keys

# --- Mistral Pixtral Vision (Primary Provider) ---
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_MODEL=pixtral-12b-2409

# --- OpenRouter (Optional Fallback) ---
# Uncomment and add your key to enable OpenRouter as a fallback provider.
# OPENROUTER_API_KEY=your_openrouter_api_key_here
# OPENROUTER_MODEL=openai/gpt-4o-mini

# --- OpenAI (Optional Fallback) ---
# Uncomment and add your key to enable OpenAI as a fallback provider.
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4o

# --- Local LLM Providers (Optional — for fully offline inference) ---
# Uncomment the relevant block if you have LM Studio or Ollama running locally.
#
# LM Studio:
# LMSTUDIO_BASE_URL=http://localhost:1234/v1
# LMSTUDIO_MODEL=qwen2.5-vl-3b-instruct
#
# Ollama:
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llava
