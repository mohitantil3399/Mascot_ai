# ==============================================================================
# Desktop Companion — Comprehensive .gitignore
# Covers Python (FastAPI/ai-orchestrator), Node.js (React/ui-frontend), and .NET (WPF/native-host)
# ==============================================================================

# --- Python / AI Orchestrator ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual Environments & Package Managers
.venv/
venv/
ENV/
env/
env.bak/
venv.bak/
.uv/
.uv_cache/
.npm/

# Environment & Secrets
.env
.env.*
*.env.local
!.env.example
*.pem
*.key
secrets.*
local.settings.json

# Logs, Caches & Databases
*.log
debug_*.txt
*.sqlite
*.sqlite3
*.db
*.db-journal
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.cache/


# --- Node.js / React UI Frontend ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-debug.log*
dist/
build/
dist-ssr/
*.local
.vite/
.next/
out/
*.tsbuildinfo
.eslintcache
coverage/


# --- C# / .NET / WPF Native Host ---
bin/
obj/
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates
*.aps
*.ncb
*.opendb
*.opensdf
*.sdf
*.cachefile
*.VC.db
*.VC.VC.opendb
TestResults/
[Bb]uild[Ll]og.*
*.[Pp]ublish.xml
*.azurePubxml
*.nupkg
*.snupkg
*.visualstudio.package.schema.json


# --- OS, IDE, and Tools ---
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.swp
*.swo
*~
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db


# --- User-Specific Launch & Build Scripts ---
# These contain machine-specific paths (e.g. custom .NET SDK location).
# Copy the corresponding .example files and edit for your environment.
launch_all.bat
apps/native-host/run_host.ps1
apps/native-host/sign_build.ps1

# --- PyPI / Build Artifacts ---
# Native host Release publish output (uploaded to GitHub Releases, not committed)
apps/native-host/publish/
# Generated mascot_ai package data (copied from build artifacts, rebuilt before each publish)
mascot_ai/ui_dist/
mascot_ai/orchestrator/
# PyPI build output
dist/
*.egg-info/
